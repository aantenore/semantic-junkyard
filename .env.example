HOST=127.0.0.1
PORT=8787
SEMANTIC_JUNKYARD_DB=data/semantic-junkyard.sqlite
SEMANTIC_JUNKYARD_SOURCE_SYSTEMS_FILE=
SEMANTIC_JUNKYARD_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
SEMANTIC_JUNKYARD_REQUEST_BODY_LIMIT=5mb
SEMANTIC_JUNKYARD_MAX_AUTONOMOUS_RISK=medium
SEMANTIC_JUNKYARD_ENABLE_LOCAL_POC=true
# Required when HOST is not loopback. External agents send it as a Bearer token.
SEMANTIC_JUNKYARD_API_TOKEN=
# Required whenever the API token is configured. Must be a distinct Bearer token.
SEMANTIC_JUNKYARD_APPROVAL_TOKEN=
VITE_API_URL=
VITE_PRODUCT_URL=http://localhost:5173
VITE_POC_URL=http://localhost:5174
VITE_DEV_API_TARGET=http://127.0.0.1:8787

# deterministic | ollama | openai-compatible
SEMANTIC_JUNKYARD_MODEL_PROVIDER=deterministic

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# OpenAI-compatible local or hosted server
OPENAI_COMPATIBLE_BASE_URL=http://localhost:8080/v1
OPENAI_COMPATIBLE_MODEL=local-model
OPENAI_COMPATIBLE_EMBEDDING_MODEL=

# Local Hugging Face / MLX audit summarizer
SEMANTIC_JUNKYARD_HF_CACHE_ROOT=
SEMANTIC_JUNKYARD_HF_MODEL=
SEMANTIC_JUNKYARD_HF_ENRICHMENT_MODEL=
SEMANTIC_JUNKYARD_HF_TIMEOUT_MS=120000
SEMANTIC_JUNKYARD_HF_MAX_TOKENS=72
