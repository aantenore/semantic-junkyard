    "seed": "tsx src/seed.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@semantic-junkyard/shared": "0.1.0",
    "better-sqlite3": "^12.5.0",
    "cors": "^2.8.5",
